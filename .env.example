# ============================================
# StraitsX API Credentials
# Used for authenticating API requests
# ============================================

# Your StraitsX API key (from the StraitsX Dashboard)
X_XFERS_APP_API_KEY=your_straitsx_api_key_here

# Path to your Ed25519 private key PEM file (for request signing)
PRIVATE_KEY_PATH=./private_key.pem

# The Key ID from the StraitsX Dashboard (after uploading your public key)
PUBLIC_KEY_ID=your_key_id_from_dashboard

# ============================================
# Callback Verification
# Used for verifying incoming StraitsX callbacks
# ============================================

# HMAC-SHA256 signing secret (from Dashboard > Platform Tools > Callback URLs > Signing Key)
STRAITSX_SIGNING_SECRET=your_signing_secret_here
